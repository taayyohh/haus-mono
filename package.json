    "@stripe/stripe-js": "^8.11.0",
    "axios": "^1.13.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "graphql-yoga": "^5.18.1",
    "next": "14.2.35",
    "phosphor-react": "^1.4.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.72.0",
    "react-intersection-observer": "^10.0.3",
