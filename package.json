{
  "name": "lucidhaus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "relay": "relay-compiler",
    "relay:watch": "relay-compiler --watch",
